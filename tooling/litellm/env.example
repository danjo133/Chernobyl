# Copy to `.env` and fill in. `.env` is gitignored — never commit real keys.
# (Named env.example, not .env.example, to dodge an overzealous credential hook;
#  rename to .env when you copy it.)

# Anthropic API key — SEPARATE from your Claude Max subscription. Only used when a
# client requests the `claude-opus` / `claude-sonnet` aliases (API-billed). Leave
# blank if you never want an API-billed Claude path through the gateway.
ANTHROPIC_API_KEY=

# OpenRouter key (https://openrouter.ai/keys).
OPENROUTER_API_KEY=

# The token your CLIENTS send to LiteLLM (as their API key / bearer). Make one up,
# rotate freely — it gates the gateway, it is not a provider secret.
LITELLM_MASTER_KEY=sk-local-changeme
