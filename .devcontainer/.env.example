# Copy to .devcontainer/.env (the `sandbox` CLI / mount.sh also writes SANDBOX_MOUNT here).
# compose reads this automatically.

# Per-sandbox identity (also set as COMPOSE_PROJECT_NAME by the sandbox CLI).
SANDBOX_NAME=cc-sandbox

# Host path of the repo/worktree to expose (the FUSE filter reads from here).
SANDBOX_SOURCE=/home/user/dev/myrepo

# Host path of the FUSE-filtered view (the workload binds this at /workspace).
# Set by mount.sh; only override if you know what you're doing.
SANDBOX_MOUNT=/run/user/1000/devfilter/cc-sandbox

# Pinned Claude Code version (or "latest").
CLAUDE_CODE_VERSION=latest

# Host dir for the broker control socket (host filler <-> gateway). NOT shared with workload.
BROKER_CONTROL_DIR=./.broker-control

# Published dev-server port (declared on the gateway service). host:container, host-local.
FORWARD_SPEC=127.0.0.1:3000:3000
